rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /eventHub/appState {
      // event-hub は共有の単一ドキュメントを全員で使うため、
      // RoomPlaner のような request.auth.uid == userId ではなく、
      // まずは「Google ログイン済みなら read / write 可」にする。
      allow read, write: if signedIn();
    }
  }
}
